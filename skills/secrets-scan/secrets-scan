#!/usr/bin/env python3
"""Scan source files for hardcoded secrets, API keys, tokens, and credentials.

Uses regex pattern matching and Shannon entropy analysis to detect secrets
in source code. Respects .gitignore and skips binary/lock files.

Exit codes:
    0 = No secrets found
    1 = Secrets detected
    2 = Usage error
"""
from __future__ import annotations

import argparse
import math
import os
import re
import subprocess
import sys
from pathlib import Path

# Maximum characters to show in redacted preview
PREVIEW_LENGTH = 40

# Minimum length for generic high-entropy string detection
MIN_ENTROPY_LENGTH = 20

# Shannon entropy threshold for flagging generic secrets
ENTROPY_THRESHOLD = 4.5

# Files to always skip
SKIP_FILES = {
    "package-lock.json",
    "yarn.lock",
    "pnpm-lock.yaml",
    "poetry.lock",
    "Pipfile.lock",
    "Gemfile.lock",
    "go.sum",
    "composer.lock",
    "Cargo.lock",
}

# Known test/placeholder values to ignore (case-insensitive substrings)
FALSE_POSITIVE_MARKERS = [
    "example",
    "placeholder",
    "changeme",
    "your_",
    "your-",
    "insert_",
    "insert-",
    "replace_",
    "replace-",
    "todo",
    "fixme",
    "xxx",
    "dummy",
    "fake",
    "test_key",
    "test-key",
    "sample",
]

# Secret patterns: (label, regex, group_index_for_value)
# group_index_for_value: which regex group contains the secret value (0 = full match)
SECRET_PATTERNS: list[tuple[str, re.Pattern[str], int]] = [
    # AWS access key ID
    ("AWS_KEY", re.compile(r"(AKIA[0-9A-Z]{16})"), 1),
    # AWS secret access key (40 chars base64 after separator)
    ("AWS_SECRET", re.compile(
        r"""(?:aws_secret_access_key|secret_key|SECRET_KEY)\s*[=:]\s*['"]?([A-Za-z0-9/+=]{40})['"]?"""
    ), 1),
    # GitHub tokens (classic PATs are 40 chars, fine-grained vary)
    ("GITHUB_TOKEN", re.compile(r"(gh[pousr]_[A-Za-z0-9_]{20,255})"), 1),
    # Slack tokens
    ("SLACK_TOKEN", re.compile(r"(xox[bpoa]-[0-9A-Za-z-]{10,})"), 1),
    # Stripe live keys
    ("STRIPE_KEY", re.compile(r"([sr]k_live_[A-Za-z0-9]{20,})"), 1),
    # Stripe publishable live key
    ("STRIPE_PK", re.compile(r"(pk_live_[A-Za-z0-9]{20,})"), 1),
    # Private keys (PEM format)
    ("PRIVATE_KEY", re.compile(r"(-----BEGIN\s+(?:RSA\s+|EC\s+|DSA\s+|OPENSSH\s+)?PRIVATE\s+KEY-----)"), 1),
    # JWT tokens (three base64 segments)
    ("JWT_TOKEN", re.compile(
        r"""['"]?(eyJ[A-Za-z0-9_-]{10,}\.eyJ[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,})['"]?"""
    ), 1),
    # Connection strings with embedded passwords
    ("CONNECTION_STRING", re.compile(
        r"((?:postgres|postgresql|mysql|mongodb|redis|amqp|mssql)://[^:]+:[^@\s]{3,}@[^\s'\"]+)"
    ), 1),
    # Generic password/secret/token/key assignments
    ("GENERIC_SECRET", re.compile(
        r"""(?:password|passwd|secret|token|api_?key|apikey|auth_?key|access_?key|private_?key|client_?secret)\s*[=:]\s*['"]([^'"]{8,})['"]""",
        re.IGNORECASE,
    ), 1),
    # Sendgrid API key
    ("SENDGRID_KEY", re.compile(r"(SG\.[A-Za-z0-9_-]{22}\.[A-Za-z0-9_-]{43})"), 1),
    # Twilio auth token (32 hex chars after assignment)
    ("TWILIO_TOKEN", re.compile(
        r"""(?:twilio_auth_token|TWILIO_AUTH_TOKEN)\s*[=:]\s*['"]?([0-9a-f]{32})['"]?"""
    ), 1),
    # Google API key
    ("GOOGLE_API_KEY", re.compile(r"(AIza[0-9A-Za-z_-]{35})"), 1),
    # Heroku API key
    ("HEROKU_KEY", re.compile(
        r"""(?:heroku_api_key|HEROKU_API_KEY)\s*[=:]\s*['"]?([0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12})['"]?"""
    ), 1),
]

# Variable names that suggest a secret (for entropy-based detection)
SECRET_VARIABLE_PATTERN = re.compile(
    r"""(?:password|passwd|secret|token|api_?key|apikey|auth_?key|access_?key|"""
    r"""private_?key|client_?secret|signing_?key|encryption_?key|master_?key|"""
    r"""database_?url|db_?url|connection_?string)\s*[=:]\s*['"]([^'"]+)['"]""",
    re.IGNORECASE,
)


def shannon_entropy(data: str) -> float:
    """Calculate Shannon entropy of a string."""
    if not data:
        return 0.0
    freq: dict[str, int] = {}
    for char in data:
        freq[char] = freq.get(char, 0) + 1
    length = len(data)
    return -sum(
        (count / length) * math.log2(count / length)
        for count in freq.values()
    )


def is_false_positive(value: str, label: str = "") -> bool:
    """Check if a matched value is likely a placeholder or test value.

    For structured values (connection strings, URLs), only checks the
    credential portion. For token-format secrets (AWS keys, GitHub tokens),
    skips substring matching since the token format itself is the signal.
    """
    lower = value.lower()
    # Skip test keys (Stripe, etc.)
    if lower.startswith(("sk_test_", "pk_test_", "rk_test_")):
        return True

    # Token-format secrets: the format IS the signal — don't check substrings
    # (e.g., AWS key ending in "EXAMPLE" is still a real key format)
    token_labels = {"AWS_KEY", "AWS_SECRET", "GITHUB_TOKEN", "SLACK_TOKEN",
                    "STRIPE_KEY", "STRIPE_PK", "SENDGRID_KEY", "GOOGLE_API_KEY",
                    "JWT_TOKEN", "PRIVATE_KEY"}
    if label in token_labels:
        return False

    # For connection strings, extract just the password portion
    if label == "CONNECTION_STRING":
        # Format: scheme://user:password@host
        cred_match = re.search(r"://[^:]+:([^@]+)@", value)
        if cred_match:
            lower = cred_match.group(1).lower()
        else:
            return False

    return any(marker in lower for marker in FALSE_POSITIVE_MARKERS)


def is_binary_file(filepath: str) -> bool:
    """Quick check if a file appears to be binary."""
    try:
        with open(filepath, "rb") as f:
            chunk = f.read(8192)
            return b"\x00" in chunk
    except OSError:
        return True


def get_staged_files() -> list[str]:
    """Get list of files staged for commit."""
    try:
        result = subprocess.run(
            ["git", "diff", "--cached", "--name-only", "--diff-filter=ACMR"],
            capture_output=True, text=True, check=True,
        )
        return [f for f in result.stdout.strip().split("\n") if f]
    except subprocess.CalledProcessError:
        return []


def get_tracked_files(paths: list[str] | None = None) -> list[str]:
    """Get list of tracked + untracked files, respecting .gitignore."""
    cmd = ["git", "ls-files", "--cached", "--others", "--exclude-standard"]
    if paths:
        cmd.extend(paths)
    try:
        result = subprocess.run(
            cmd, capture_output=True, text=True, check=True,
        )
        return [f for f in result.stdout.strip().split("\n") if f]
    except subprocess.CalledProcessError:
        return []


def redact(value: str) -> str:
    """Redact a secret value for display."""
    if len(value) <= 8:
        return value[:2] + "..." + "REDACTED"
    return value[:8] + "...REDACTED"


def scan_file(filepath: str) -> list[tuple[int, str, str]]:
    """Scan a single file for secrets.

    Returns list of (line_number, label, redacted_preview).
    """
    findings: list[tuple[int, str, str]] = []

    try:
        with open(filepath, encoding="utf-8", errors="replace") as f:
            lines = f.readlines()
    except OSError:
        return findings

    for line_num, line in enumerate(lines, start=1):
        stripped = line.strip()
        if not stripped or stripped.startswith("#") or stripped.startswith("//"):
            # Skip empty lines and comments (simple heuristic)
            continue

        # Check each secret pattern
        for label, pattern, group_idx in SECRET_PATTERNS:
            match = pattern.search(line)
            if match:
                value = match.group(group_idx)
                if not is_false_positive(value, label):
                    findings.append((line_num, label, redact(value)))
                    break  # one finding per line

        else:
            # Entropy-based detection for variable assignments
            var_match = SECRET_VARIABLE_PATTERN.search(line)
            if var_match:
                value = var_match.group(1)
                if (
                    len(value) >= MIN_ENTROPY_LENGTH
                    and not is_false_positive(value)
                    and shannon_entropy(value) > ENTROPY_THRESHOLD
                ):
                    findings.append((line_num, "HIGH_ENTROPY", redact(value)))

    return findings


def check_env_file(filepath: str) -> list[tuple[int, str, str]]:
    """Check if a .env file contains secrets."""
    findings: list[tuple[int, str, str]] = []
    secret_env_vars = re.compile(
        r"""^(?:.*(?:PASSWORD|SECRET|TOKEN|KEY|API_KEY|AUTH|PRIVATE|CREDENTIAL|DATABASE_URL|DB_URL).*)\s*=\s*(.+)""",
        re.IGNORECASE,
    )

    try:
        with open(filepath, encoding="utf-8", errors="replace") as f:
            for line_num, line in enumerate(f, start=1):
                stripped = line.strip()
                if not stripped or stripped.startswith("#"):
                    continue
                match = secret_env_vars.match(stripped)
                if match:
                    value = match.group(1).strip().strip("'\"")
                    if value and not is_false_positive(value):
                        findings.append((line_num, "ENV_SECRET", redact(value)))
    except OSError:
        pass

    return findings


def main() -> None:
    parser = argparse.ArgumentParser(
        description="Scan files for hardcoded secrets and credentials.",
    )
    parser.add_argument(
        "--all", action="store_true",
        help="Scan entire working tree (default: staged files only)",
    )
    parser.add_argument(
        "paths", nargs="*",
        help="Specific paths to scan (implies --all behavior for those paths)",
    )
    args = parser.parse_args()

    # Determine which files to scan
    if args.paths:
        # For explicit paths, include both git-tracked files and direct file paths
        files = get_tracked_files(args.paths)
        # Also include any explicitly provided files that exist but weren't in git output
        for p in args.paths:
            if os.path.isfile(p) and p not in files:
                files.append(p)
            elif os.path.isdir(p):
                # Walk directories for non-git paths
                for root, _dirs, filenames in os.walk(p):
                    for fname in filenames:
                        fpath = os.path.join(root, fname)
                        if fpath not in files:
                            files.append(fpath)
    elif args.all:
        files = get_tracked_files()
    else:
        files = get_staged_files()
        if not files:
            print("No staged files. Use --all to scan the working tree or specify paths.")
            sys.exit(0)

    total_findings: list[tuple[str, int, str, str]] = []

    for filepath in files:
        # Skip non-existent, binary, and lock files
        if not os.path.isfile(filepath):
            continue
        if os.path.basename(filepath) in SKIP_FILES:
            continue
        if is_binary_file(filepath):
            continue

        # Check .env files specially
        if os.path.basename(filepath).startswith(".env"):
            for line_num, label, preview in check_env_file(filepath):
                total_findings.append((filepath, line_num, label, preview))
            continue

        # Scan regular files
        for line_num, label, preview in scan_file(filepath):
            total_findings.append((filepath, line_num, label, preview))

    if not total_findings:
        print("No secrets detected.")
        sys.exit(0)

    # Report findings
    max_path_len = max(
        len(f"{fp}:{ln}") for fp, ln, _, _ in total_findings
    )

    for filepath, line_num, label, preview in total_findings:
        location = f"{filepath}:{line_num}"
        print(f"  {location:<{max_path_len + 2}} [{label}]  {preview}")

    print(f"\n{len(total_findings)} potential secret(s) found.")
    sys.exit(1)


if __name__ == "__main__":
    main()
