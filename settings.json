{
  "permissions": {
    "allow": [
      "Read(~/.claude/**)",
      "Grep",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__list_pages",
      "Bash(~/.claude/skills/md2latex/md2latex application/resume.md)",
      "Bash(~/.claude/skills/md2latex/md2latex application/cover-letter.md)",
      "Bash(~/.claude/skills/md2latex/md2latex prep/study-guide-resources.md)",
      "Bash(~/.claude/skills/md2latex/md2latex research/building-effective-agents-review.md)",
      "Bash(~/.claude/skills/md2latex/md2latex research/rag-mcp-context-engineering.md)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(wc -l src/scripts/*.ts)",
      "Bash(~/.claude/skills/md2latex/md2latex prep/stories.md)",
      "Bash(pandoc -t latex)",
      "Edit(~/.claude/skills/md2latex/**)",
      "Bash(npm run:*)",
      "Bash(npm install:*)",
      "Bash(npx vitest:*)",
      "Bash(npx tsc:*)",
      "Bash(npx eslint:*)",
      "Bash(git add:*)",
      "Bash(~/.claude/skills/md2latex/md2latex prep/stories.md --output-dir pdf-output/prep)",
      "Bash(git status:*)",
      "Bash(~/.claude/skills/md2latex/md2latex prep/technical-discussion-prep.md --output-dir pdf-output/prep)",
      "Bash(find ~/.claude -type f -name *.md -o -name *.json -o -name *.yaml -o -name *.yml)",
      "Bash(~/.claude/skills/sync-pdfs/sync-pdfs)",
      "Bash(~/.claude/skills/check-prose/check-prose)",
      "Bash(~/.claude/skills/sync-pdfs/sync-pdfs --dry-run)"
    ],
    "additionalDirectories": [
      "/tmp",
      "~/.claude/skills"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path // .tool_response.filePath // empty'); if [[ -n \"$FILE\" ]] && [[ \"$FILE\" =~ \\.(tsx|jsx)$ ]]; then printf '{\"hookSpecificOutput\":{\"hookEventName\":\"PostToolUse\",\"additionalContext\":\"REACT FILE MODIFIED: %s — Use the react-reviewer agent to review this change before proceeding.\"}}' \"$FILE\"; fi",
            "statusMessage": "Checking for React file changes..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path // .tool_response.filePath // empty'); if [[ -n \"$FILE\" ]] && [[ \"$FILE\" =~ \\.py$ ]]; then printf '{\"hookSpecificOutput\":{\"hookEventName\":\"PostToolUse\",\"additionalContext\":\"PYTHON FILE MODIFIED: %s — Use the python-reviewer agent to review this change before proceeding.\"}}' \"$FILE\"; fi",
            "statusMessage": "Checking for Python file changes..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/check-test-modification.py"
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/enforce-tdd.py",
            "statusMessage": "Checking TDD compliance..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/reset-tdd-on-commit.py"
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/enforce-atomic-commits.py",
            "statusMessage": "Checking commit atomicity..."
          }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/check-webfetch.js",
            "timeout": 15
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c 'tee /tmp/statusline-input.json | bash ~/.claude/statusline-command.sh'"
  },
  "enabledPlugins": {
    "chrome-devtools-mcp@chrome-devtools-plugins": true
  },
  "effortLevel": "high"
}
